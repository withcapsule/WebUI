{
	"name": "capsule-webui",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Static WebUI for Capsule. The only build step bundles the self-hosted crypto module.",
	"scripts": {
		"build:crypto": "esbuild crypto-src/capsule-crypto.js --bundle --format=iife --global-name=CapsuleCrypto --outfile=public/vendor/capsule-crypto.js --minify"
	},
	"devDependencies": {
		"@scure/bip39": "^2.2.0",
		"age-encryption": "^0.3.0",
		"esbuild": "^0.28.1"
	}
}
